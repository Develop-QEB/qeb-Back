generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model proveedores {
  id                 Int                 @id @default(autoincrement())
  nombre             String              @db.VarChar(255)
  direccion          String?             @db.VarChar(255)
  ciudad             String?             @db.VarChar(255)
  codigo_postal      String?             @db.VarChar(255)
  telefono           String?             @db.VarChar(255)
  email              String?             @db.VarChar(255)
  sitio_web          String?             @db.VarChar(255)
  contacto_principal String?             @db.VarChar(255)
  categoria          String?             @db.VarChar(255)
  fecha_alta         DateTime?           @db.Date
  estado             proveedores_estado? @default(activo)
  notas              String?             @db.Text
  deleted_at         DateTime?           @db.Date

  @@map("proveedores")
}

model inventarios {
  id                   Int      @id @default(autoincrement())
  codigo_unico         String?  @db.VarChar(255)
  ubicacion            String?  @db.VarChar(255)
  tipo_de_cara         String?  @db.VarChar(255)
  cara                 String?  @db.VarChar(255)
  mueble               String?  @db.VarChar(255)
  latitud              Float    @db.Float
  longitud             Float    @db.Float
  plaza                String?  @db.VarChar(255)
  estado               String?  @db.VarChar(255)
  municipio            String?  @db.Text
  cp                   Int?
  tradicional_digital  String?  @db.VarChar(255)
  sentido              String?  @db.VarChar(255)
  tipo_de_mueble       String?  @db.Text
  ancho                Float    @db.Float
  alto                 Float    @db.Float
  archivos_id          Int?
  nivel_socioeconomico String?  @db.VarChar(255)
  total_espacios       Int?
  tiempo               Int?
  estatus              String?  @db.VarChar(255)
  codigo               String?  @db.VarChar(255)
  col_5354             Boolean?
  isla                 String?  @db.VarChar(255)
  mueble_isla          String?  @db.VarChar(255)
  entre_calle_1        String?  @db.VarChar(255)
  entre_calle_2        String?  @db.VarChar(255)
  orientacion          String?  @db.VarChar(255)
  tarifa_piso          Decimal? @db.Decimal(12, 2)
  tarifa_publica       Decimal? @db.Decimal(12, 2)
  mundialista          String?  @db.VarChar(10)

  @@index([archivos_id], map: "idx_archivos_id")
  @@map("inventarios")
}

model catorcenas {
  id               Int      @id @default(autoincrement())
  a_o              Int      @map("año")
  numero_catorcena Int
  fecha_inicio     DateTime @db.Date
  fecha_fin        DateTime @db.Date

  @@index([fecha_inicio, fecha_fin], map: "idx_fechas")
  @@index([a_o, numero_catorcena], map: "idx_ano_catorcena")
  @@map("catorcenas")
}

model archivos {
  id           Int    @id @default(autoincrement())
  nombre       String @db.VarChar(255)
  tipo         String @db.VarChar(255)
  campana_id   Int
  tareas_id    Int
  alto         String @db.VarChar(255)
  ancho        String @db.VarChar(255)
  idinventario String @db.VarChar(255)
}

model calendario {
  id           Int       @id @default(autoincrement())
  fecha_inicio DateTime  @default(dbgenerated("(curdate())")) @db.Date
  fecha_fin    DateTime  @default(dbgenerated("(curdate() + interval 3 day)")) @db.Date
  deleted_at   DateTime? @db.Date
}

model campania {
  id               Int       @id @default(autoincrement())
  cliente_id       Int
  nombre           String    @db.VarChar(255)
  fecha_inicio     DateTime  @db.Date
  fecha_fin        DateTime  @db.Date
  total_caras      String    @db.VarChar(255)
  bonificacion     Int
  status           String    @default("inactiva") @db.VarChar(255)
  cotizacion_id    Int?
  articulo         String    @db.VarChar(255)
  fecha_aprobacion DateTime? @db.DateTime(0)
  posted_to_sap    Int?      @default(0) @db.TinyInt
  posted_aps       String?   @db.Text

  @@index([cotizacion_id], map: "idx_cotizacion_id")
  @@index([id, fecha_inicio, fecha_fin], map: "idx_campania_fechas")
}

model cliente {
  id                 Int       @id @default(autoincrement())
  CUIC               Int?
  T0_U_IDAsesor      Int?
  T0_U_Asesor        String?   @db.VarChar(255)
  T0_U_IDAgencia     Int?
  T0_U_Agencia       String?   @db.VarChar(255)
  T0_U_Cliente       String?   @db.VarChar(255)
  T0_U_RazonSocial   String?   @db.VarChar(255)
  T0_U_IDACA         Int?
  T1_U_Cliente       String?   @db.VarChar(255)
  T1_U_IDACA         Int?
  T1_U_IDCM          Int?
  T1_U_IDMarca       Int?
  T1_U_UnidadNegocio String?   @db.VarChar(255)
  T1_U_ValidFrom     DateTime? @db.Date
  T1_U_ValidTo       DateTime? @db.Date
  T2_U_IDCategoria   Int?
  T2_U_Categoria     String?   @db.VarChar(255)
  T2_U_IDCM          Int?
  T2_U_IDProducto    Int?
  T2_U_Marca         String?   @db.VarChar(255)
  T2_U_Producto      String?   @db.VarChar(255)
  T2_U_ValidFrom     DateTime? @db.Date
  T2_U_ValidTo       DateTime? @db.Date
  card_code          String?   @db.VarChar(255)
  salesperson_code   Int?
  sap_database       String?   @db.VarChar(255)
}

model comentarios {
  id           Int      @id @default(autoincrement())
  autor_id     Int
  comentario   String   @db.Text
  creado_en    DateTime @db.Timestamp(0)
  campania_id  Int
  solicitud_id Int
  origen       String?  @db.VarChar(255)
}

model cotizacion {
  id                   Int       @id @default(autoincrement())
  user_id              Int
  clientes_id          Int
  nombre_campania      String    @db.VarChar(255)
  numero_caras         Int
  fecha_inicio         DateTime  @db.Date
  fecha_fin            DateTime  @db.Date
  frontal              Int
  cruzada              Int
  nivel_socioeconomico String?   @db.VarChar(500)
  observaciones        String    @db.VarChar(255)
  bonificacion         Float
  descuento            Float
  precio               Decimal?  @db.Decimal(10, 2)
  contacto             String    @db.VarChar(255)
  status               String    @default("Pendiente") @db.VarChar(255)
  id_propuesta         Int
  fecha_expiracion     DateTime? @db.Date
  articulo             String    @db.VarChar(255)
  tipo_periodo         String?   @default("catorcena") @db.VarChar(255)

  @@index([id_propuesta], map: "idx_id_propuesta")
}

model espacio_inventario {
  id             Int @id @default(autoincrement())
  inventario_id  Int
  numero_espacio Int

  @@index([inventario_id], map: "idx_inventario_id")
}

model historial {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tipo       String   @db.VarChar(255)
  ref_id     Int
  accion     String   @db.VarChar(255)
  fecha_hora DateTime @default(now()) @db.Timestamp(0)
  detalles   String?  @db.Text
}

model historial_comentarios {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  id_propuesta Int
  comentario   String    @db.Text
  nuevo_status String?   @db.VarChar(255)
  usuario      String?   @db.VarChar(255)
  fecha        DateTime? @default(now()) @db.Timestamp(0)
}

model imagenes_digitales {
  id                 Int      @id @default(autoincrement())
  id_reserva         Int
  archivo            String   @db.VarChar(255)
  comentario         String   @db.Text
  aprobado_rechazado String   @db.VarChar(255)
  respuesta          String   @db.VarChar(255)
  spot               Int
  fecha_testigo      DateTime @db.Date
  imagen_testigo     String   @db.Text
  archivo_data       String?  @db.LongText

  @@index([id_reserva], map: "idx_id_reserva")
}

model artes_tradicionales {
  id         Int      @id @default(autoincrement())
  id_reserva Int
  archivo    String   @db.VarChar(255)
  nota       String   @db.Text
  spot       Int      @default(1)
  created_at DateTime @default(now()) @db.DateTime(0)

  @@index([id_reserva], map: "idx_at_id_reserva")
}

model propuesta {
  id                       Int       @id @default(autoincrement())
  cliente_id               Int
  fecha                    DateTime  @default(dbgenerated("(curdate())")) @db.Date
  status                   String    @default("Abierto") @db.VarChar(255)
  descripcion              String?   @db.Text
  precio                   Decimal?  @db.Decimal(10, 2)
  notas                    String?   @db.Text
  deleted_at               DateTime? @db.DateTime(0)
  solicitud_id             Int
  precio_simulado          Int?
  asignado                 String    @db.Text
  id_asignado              String?   @db.Text
  inversion                Decimal  @default(0) @db.Decimal(12, 2)
  comentario_cambio_status String    @db.Text
  articulo                 String    @db.VarChar(255)
  updated_at               DateTime? @default(now()) @db.Timestamp(0)
  archivo                  String?   @db.VarChar(255)

  @@index([deleted_at, status], map: "idx_propuesta_deleted_status")
  @@index([solicitud_id], map: "idx_propuesta_solicitud")
  @@index([cliente_id], map: "idx_propuesta_cliente")
}

model reservas {
  id                 Int       @id @default(autoincrement())
  inventario_id      Int
  calendario_id      Int
  cliente_id         Int
  fecha_reserva      DateTime? @default(dbgenerated("(curdate())")) @db.Date
  deleted_at         DateTime? @db.DateTime(0)
  solicitudCaras_id  Int
  archivo            String?   @db.LongText
  estatus            String    @db.VarChar(255)
  arte_aprobado      String    @db.VarChar(255)
  comentario_rechazo String    @db.VarChar(255)
  estatus_original   String    @db.VarChar(255)
  fecha_testigo      DateTime  @db.Date
  imagen_testigo     String    @db.Text
  instalado          Boolean
  APS                Int?
  tarea              String    @db.VarChar(255)
  grupo_completo_id  Int?

  @@index([solicitudCaras_id])
  @@index([APS])
  @@index([deleted_at], map: "idx_deleted_at")
  @@index([inventario_id], map: "idx_inventario_id")
  @@index([grupo_completo_id], map: "idx_grupo_completo")
  @@index([archivo(length: 100)], map: "idx_rsv_archivo")
  @@index([solicitudCaras_id, deleted_at, APS, grupo_completo_id], map: "idx_rsv_query_sin_arte")
  @@index([deleted_at, estatus], map: "idx_rsv_deleted_estatus")
}

model session_locks {
  id          Int       @id @default(autoincrement())
  module_name String    @db.VarChar(255)
  user_id     Int?
  username    String?   @db.VarChar(255)
  locked_at   DateTime? @default(now()) @db.Timestamp(0)
}

model solicitud {
  id               Int       @id @default(autoincrement())
  fecha            DateTime  @default(now()) @db.DateTime(0)
  descripcion      String    @db.Text
  presupuesto      Decimal   @db.Decimal(10, 2)
  notas            String    @db.Text
  cliente_id       Int
  usuario_id       Int?
  status           String    @default("Pendiente") @db.VarChar(255)
  deleted_at       DateTime? @db.DateTime(0)
  nombre_usuario   String?   @db.VarChar(255)
  asignado         String    @db.Text
  id_asignado      String?   @db.Text
  cuic             String?   @db.VarChar(255)
  razon_social     String?   @db.VarChar(255)
  unidad_negocio   String?   @db.VarChar(255)
  marca_id         Int?
  marca_nombre     String?   @db.VarChar(255)
  asesor           String?   @db.VarChar(255)
  producto_id      Int?
  producto_nombre  String?   @db.VarChar(255)
  agencia          String?   @db.VarChar(255)
  categoria_id     Int?
  categoria_nombre String?   @db.VarChar(255)
  IMU              Int
  archivo          String?   @db.LongText
  tipo_archivo     String?   @db.VarChar(255)
  card_code        String?   @db.VarChar(255)
  salesperson_code Int?
  sap_database     String?   @db.VarChar(255)
}

model solicitudCaras {
  id                   Int      @id @default(autoincrement())
  idquote              String?  @db.VarChar(255)
  ciudad               String?  @db.VarChar(1000)
  estados              String?  @db.VarChar(1000)
  tipo                 String?  @db.VarChar(255)
  flujo                String?  @db.VarChar(255)
  bonificacion         Decimal? @db.Decimal(10, 2)
  caras                Int
  nivel_socioeconomico String   @db.VarChar(500)
  formato              String   @db.VarChar(1000)
  costo                Decimal  @default(0) @db.Decimal(12, 2)
  tarifa_publica       Decimal  @default(0) @db.Decimal(12, 2)
  inicio_periodo       DateTime @default(dbgenerated("(curdate())")) @db.Date
  fin_periodo          DateTime @default(dbgenerated("(curdate())")) @db.Date
  caras_flujo          Int?     @default(0)
  caras_contraflujo    Int?     @default(0)
  articulo             String?  @db.VarChar(255)
  descuento            Decimal? @db.Decimal(5, 2)
  autorizacion_dg      String?  @default("aprobado") @db.VarChar(255)
  autorizacion_dcm     String?  @default("aprobado") @db.VarChar(255)
  cortesia             Int?     @default(0)

  @@index([idquote])
  @@index([inicio_periodo, fin_periodo], map: "idx_periodos")
}

model tareas {
  id                 Int       @id @default(autoincrement())
  fecha_inicio       DateTime  @default(dbgenerated("(curdate())")) @db.DateTime(0)
  fecha_fin          DateTime  @default(now()) @db.DateTime(0)
  tipo               String?   @db.VarChar(255)
  responsable        String?   @db.VarChar(255)
  id_responsable     Int
  estatus            String?   @db.VarChar(255)
  descripcion        String?   @db.Text
  titulo             String?   @db.VarChar(255)
  contenido          String?   @db.Text
  campania_id        Int?
  archivo            String?   @db.VarChar(1000)
  id_solicitud       String    @db.VarChar(255)
  id_propuesta       String?   @db.VarChar(255)
  evidencia          String?   @db.VarChar(10000)
  proveedores_id     Int?
  listado_inventario String?   @db.Text
  nombre_proveedores String?   @db.Text
  asignado           String?   @db.Text
  id_asignado        String?   @db.Text
  ids_reservas       String?   @db.Text
  num_impresiones    Int?
  archivo_testigo    String?   @db.VarChar(1000)
  created_at         DateTime? @default(now()) @db.Timestamp(0)

  @@index([campania_id])
  @@index([campania_id, id_responsable], map: "idx_tareas_campania_responsable")
}

model usuario {
  id                 Int              @id @default(autoincrement())
  nombre             String           @db.VarChar(255)
  correo_electronico String           @db.VarChar(255)
  user_password      String?          @db.VarChar(255)
  area               String           @db.VarChar(255)
  puesto             String           @db.VarChar(255)
  updated_at         DateTime?        @db.Timestamp(0)
  created_at         DateTime?        @default(now()) @db.Timestamp(0)
  deleted_at         DateTime?        @db.Timestamp(0)
  user_role          String           @default("Normal") @db.VarChar(255)
  foto_perfil        String?          @db.VarChar(500)
  reset_token        String?          @db.VarChar(6)
  reset_token_expiry DateTime?        @db.DateTime(0)
  sap_asesor_id      Int?
  light_theme_notified Boolean @default(false)
  version_notified     String?  @db.VarChar(20)
  equipos            usuario_equipo[]
}

model version {
  id     Int    @id @default(autoincrement())
  numero String @db.VarChar(20)
  fecha  DateTime @db.Date
}

model equipo {
  id          Int              @id @default(autoincrement())
  nombre      String           @db.VarChar(255)
  descripcion String?          @db.Text
  color       String?          @db.VarChar(255)
  created_at  DateTime?        @default(now()) @db.Timestamp(0)
  updated_at  DateTime?        @db.Timestamp(0)
  deleted_at  DateTime?        @db.Timestamp(0)
  miembros    usuario_equipo[]
}

model usuario_equipo {
  id         Int       @id @default(autoincrement())
  usuario_id Int
  equipo_id  Int
  rol        String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  equipo     equipo    @relation(fields: [equipo_id], references: [id], onDelete: Cascade)
  usuario    usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, equipo_id])
  @@index([usuario_id])
  @@index([equipo_id])
}

model correos_enviados {
  id           Int      @id @default(autoincrement())
  remitente    String   @db.VarChar(255)
  destinatario String   @db.VarChar(255)
  asunto       String   @db.VarChar(500)
  cuerpo       String   @db.Text
  fecha_envio  DateTime @default(now()) @db.DateTime(0)
  leido        Boolean  @default(false)

  @@map("correos_enviados")
}

model notas_personales {
  id                  Int       @id @default(autoincrement())
  usuario_id          Int
  titulo              String?   @db.VarChar(255)
  contenido           String    @db.Text
  color               String?   @db.VarChar(255)
  fecha_creacion      DateTime  @default(now()) @db.Timestamp(0)
  fecha_actualizacion DateTime? @db.Timestamp(0)

  @@map("notas_personales")
}

model comentarios_revision_artes {
  id           Int      @id @default(autoincrement())
  tarea_id     Int
  autor_id     Int
  autor_nombre String   @db.VarChar(255)
  contenido    String   @db.Text
  fecha        DateTime @default(now()) @db.Timestamp(0)
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model conteoTradicionalYDigital {
  Tradicional BigInt?
  Digital     BigInt?

  @@ignore
}

model criterios_autorizacion {
  id             Int      @id @default(autoincrement())
  formato        String   @db.VarChar(255)
  tipo           String   @db.VarChar(255)
  plaza          String   @db.VarChar(255)
  tarifa_max_dg  Decimal? @db.Decimal(10, 2)
  tarifa_min_dcm Decimal? @db.Decimal(10, 2)
  tarifa_max_dcm Decimal? @db.Decimal(10, 2)
  caras_max_dg   Int?
  caras_min_dcm  Int?
  caras_max_dcm  Int?
  activo         Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamp(0)
}

model solicitud_original {
  id              Int      @id @default(autoincrement())
  fecha           DateTime @default(now()) @db.DateTime(0)
  descripcion     String   @db.Text
  presupuesto     Decimal  @db.Decimal(10, 2)
  notas           String   @db.Text
  cliente_id      Int
  usuario_id      Int?
  status          String   @default("Pendiente") @db.VarChar(255)
  nombre_usuario  String?  @db.VarChar(255)
  propuesta_id    Int
  nombre_campania String   @db.VarChar(255)
  fecha_inicio    DateTime @db.Date
  fecha_fin       DateTime @db.Date
  flujo           Int      @default(0)
  contraflujo     Int      @default(0)
  total_flujo     Int      @default(0)
  bonificacion    Int      @default(0)
  nombre_cliente  String?  @db.VarChar(255)
  articulo        String   @db.VarChar(255)
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model vista_conteo_por_ciudades {
  municipio String? @db.Text
  total     BigInt?

  @@ignore
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model vista_conteo_por_muebles {
  tipo_de_mueble     String? @db.Text
  conteo_inventarios BigInt?

  @@ignore
}

model tickets {
  id                  Int               @id @default(autoincrement())
  titulo              String            @db.VarChar(255)
  descripcion         String            @db.Text
  imagen              String?           @db.LongText
  status              String            @default("Nuevo") @db.VarChar(255)
  prioridad           String            @default("Normal") @db.VarChar(255)
  usuario_id          Int
  usuario_nombre      String            @db.VarChar(255)
  usuario_email       String            @db.VarChar(255)
  respuesta           String?           @db.Text
  respondido_por      String?           @db.VarChar(255)
  respondido_at       DateTime?         @db.DateTime(0)
  created_at          DateTime          @default(now()) @db.DateTime(0)
  updated_at          DateTime          @updatedAt @db.DateTime(0)
  status_cambiado_por String?           @db.VarChar(255)
  mensajes            ticket_mensajes[]
  vistas              ticket_vistas[]
  chat                ticket_chat[]
  chat_vistas         ticket_chat_vistas[]

  @@map("tickets")
}

model ticket_mensajes {
  id             Int      @id @default(autoincrement())
  ticket_id      Int
  usuario_id     Int
  usuario_nombre String   @db.VarChar(255)
  mensaje        String?  @db.Text
  archivo_url    String?  @db.VarChar(500)
  archivo_nombre String?  @db.VarChar(255)
  archivo_tipo   String?  @db.VarChar(255)
  created_at     DateTime @default(now()) @db.DateTime(0)
  ticket         tickets  @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@map("ticket_mensajes")
}

model ticket_vistas {
  id                      Int      @id @default(autoincrement())
  ticket_id               Int
  usuario_id              Int
  opened_at               DateTime @default(now()) @db.DateTime(0)
  ultimo_mensaje_leido_id Int?
  ticket                  tickets  @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@unique([ticket_id, usuario_id])
  @@map("ticket_vistas")
}

model ticket_chat {
  id             Int      @id @default(autoincrement())
  ticket_id      Int
  usuario_id     Int
  usuario_nombre String   @db.VarChar(255)
  mensaje        String?  @db.Text
  archivo_url    String?  @db.VarChar(500)
  archivo_nombre String?  @db.VarChar(255)
  archivo_tipo   String?  @db.VarChar(255)
  created_at     DateTime @default(now()) @db.DateTime(0)
  ticket         tickets  @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@map("ticket_chat")
}

model ticket_chat_vistas {
  id                      Int      @id @default(autoincrement())
  ticket_id               Int
  usuario_id              Int
  ultimo_mensaje_leido_id Int?
  ticket                  tickets  @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@unique([ticket_id, usuario_id])
  @@map("ticket_chat_vistas")
}

model chatbot_logs {
  id          Int       @id @default(autoincrement())
  user_id     Int
  user_nombre String    @db.VarChar(255)
  user_email  String    @db.VarChar(255)
  rol         String?   @db.VarChar(255)
  pantalla    String?   @db.VarChar(255)
  modal       String?   @db.VarChar(255)
  pregunta    String    @db.Text
  respuesta   String    @db.Text
  categoria   String?   @db.VarChar(255)
  off_topic   Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
}

enum proveedores_estado {
  activo
  inactivo
}
